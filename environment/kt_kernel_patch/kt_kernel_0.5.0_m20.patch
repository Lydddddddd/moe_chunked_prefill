 # Import main API
 from .experts import KTMoEWrapper

+
+def generate_gpu_experts_masks(activation_freq, num_gpu_experts):
+    """Generate a boolean GPU-expert mask from activation frequencies.
+
+    Compatibility helper for SGLang's KT EP wrapper.
+    Select the globally top-k layer/expert positions from a 2D tensor
+    shaped [num_layers, num_experts].
+    """
+    import torch
+
+    if not isinstance(activation_freq, torch.Tensor):
+        activation_freq = torch.as_tensor(activation_freq)
+    if activation_freq.dim() != 2:
+        raise ValueError(
+            f"activation_freq must be 2D [num_layers, num_experts], got shape {tuple(activation_freq.shape)}"
+        )
+
+    num_layers, num_experts = activation_freq.shape
+    masks = torch.zeros((num_layers, num_experts), dtype=torch.bool, device="cpu")
+
+    num_to_select = min(int(num_gpu_experts), num_layers * num_experts)
+    if num_to_select <= 0:
+        return masks
+
+    flat_scores = activation_freq.reshape(-1).to(dtype=torch.float32, device="cpu")
+    topk = torch.topk(flat_scores, k=num_to_select, largest=True, sorted=False).indices
+    masks.view(-1)[topk] = True
+    return masks
+
